# Janus HTTP Transport Configuration for YAHAML (v1.4.1+)
# Enables both regular API and Admin HTTP endpoints

general: {
  json = "indented"
  base_path = "/janus"
  http = true
  port = 8088
  https = false
}

admin: {
  admin_base_path = "/admin"
  admin_http = true
  admin_port = 7088
  admin_https = false
  # Secret will be injected at runtime via entrypoint
}

cors: {
  allow_origin = "*"
}
