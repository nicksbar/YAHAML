{
  "name": "yahaml-relay",
  "version": "1.0.0",
  "description": "YAHAML - Relay server and database for field day logging",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run db:generate:auto && ts-node src/index.ts",
    "dev:api": "npm run db:generate:auto && ts-node src/index.ts",
    "dev:ui": "npm --prefix ui run dev",
    "dev:all": "concurrently -n api,ui -c blue,green \"npm run dev:api\" \"npm run dev:ui\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:generate:auto": "node scripts/prisma-generate-auto.cjs",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:seed": "ts-node prisma/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:browser": "playwright test",
    "test:browser:headed": "playwright test --headed",
    "test:browser:local": "PLAYWRIGHT_USE_EXISTING_SERVER=true PLAYWRIGHT_API_PORT=3000 PLAYWRIGHT_UI_PORT=5173 playwright test",
    "test:full": "npm test -- --runInBand && npm run test:browser",
    "cw:agent": "ts-node src/agent/cw/cli.ts",
    "relay": "ts-node scripts/n3fjp_mitm_relay.ts",
    "relay:default": "ts-node scripts/n3fjp_mitm_relay.ts 2000 localhost 1000",
    "lint": "eslint src --ext .ts --max-warnings 0 && npm --prefix ui run lint"
  },
  "keywords": [
    "field-day",
    "logging",
    "relay",
    "ADIF"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.43",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "concurrently": "^9.2.3",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
