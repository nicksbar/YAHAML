{
  "name": "yahaml-relay",
  "version": "1.0.0",
  "description": "YAHAML - Relay server and database for field day logging",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run db:generate:auto && ts-node src/index.ts",
    "dev:api": "npm run db:generate:auto && ts-node src/index.ts",
    "dev:ui": "npm --prefix ui run dev",
    "dev:janus": "docker compose up -d janus || docker-compose up -d janus",
    "dev:all": "npm run dev:janus && concurrently -n api,ui -c blue,green \"npm run dev:api\" \"npm run dev:ui\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:generate:auto": "node scripts/prisma-generate-auto.cjs",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:seed": "ts-node prisma/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:browser": "PLAYWRIGHT_USE_EXISTING_SERVER=false playwright test",
    "test:browser:headed": "playwright test --headed",
    "test:browser:local": "PLAYWRIGHT_USE_EXISTING_SERVER=true PLAYWRIGHT_API_PORT=3000 PLAYWRIGHT_UI_PORT=5173 playwright test",
    "test:browser:compose": "bash scripts/playwright-setup.sh",
    "test:browser:ci": "PLAYWRIGHT_USE_DOCKER_COMPOSE=true playwright test",
    "test:full": "npm test -- --runInBand && npm run test:browser",
    "test:full:compose": "npm test -- --runInBand && npm run test:browser:compose",
    "cw:agent": "ts-node src/agent/cw/cli.ts",
    "relay": "ts-node scripts/n3fjp_mitm_relay.ts",
    "relay:default": "ts-node scripts/n3fjp_mitm_relay.ts 2000 localhost 1000",
    "lint": "eslint src --ext .ts --max-warnings 0 && npm --prefix ui run lint"
  },
  "keywords": [
    "field-day",
    "logging",
    "relay",
    "ADIF"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/ssh2": "^1.15.5",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ssh2": "^1.17.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
